{
    "destination": "/path/to/backup/directory",
    "workers": 5,
    "retries": 5,
    "timeout": 120,
    "session_dir": "/path/to/session/state",
    "use_keyring": false,
    "china_mainland": false,
    "resume": true,
    "progress": true,
    "include": [
        "*.jpg",
        "*.png",
        "*.pdf",
        "Documents/*"
    ],
    "exclude": [
        "*.tmp",
        "*/Cache/*",
        "*/.Trash/*"
    ],
    "max_depth": 10,
    "log_level": "INFO"
}